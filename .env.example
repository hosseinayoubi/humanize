# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Prisma / Postgres
# For serverless runtime prefer the Supabase Pooler connection string.
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?sslmode=require
# For migrations prefer the direct connection.
DIRECT_URL=postgresql://USER:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-opus-4-5-20251101

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
